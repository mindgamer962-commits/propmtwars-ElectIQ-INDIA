rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Feedback: Anyone can read, only logged in users can create.
    // Users can only delete their own feedback.
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete, update: if request.auth != null && request.auth.uid == resource.data.uid;
    }
    
    // Quiz Scores: Anyone can create (even anonymous), only admin can read all.
    match /quiz_scores/{scoreId} {
      allow create: if true;
      allow read: if false; // Secure scores from public view
    }
  }
}
